# ── LLM ──────────────────────────────────────────────────────────────────────
# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults shown
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── STT (Speech-to-Text / Voice I/O) ─────────────────────────────────────────
# Options:
#   groq           — Recommended. Free cloud API, no native DLLs, no ffmpeg needed.
#                    Requires a GROQ_API_KEY (free account at https://console.groq.com).
#                    Free tier: 7,200 audio seconds/day — plenty for personal use.
#   faster_whisper — Local inference. No API key needed. Requires ffmpeg on PATH.
#                    May be blocked by Windows Smart App Control on some machines.
STT_PROVIDER=groq
GROQ_API_KEY=gsk_...

# ── Interview ─────────────────────────────────────────────────────────────────
EXTRACTION_INTERVAL=3

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=data

# ── faster-whisper (only used when STT_PROVIDER=faster_whisper) ───────────────
WHISPER_MODEL_SIZE=base
